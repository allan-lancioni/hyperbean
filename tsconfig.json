{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": "./packages",
    "outDir": "dist"
  },
  "include": ["packages/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
