# Dependencies
node_modules/

# TypeScript / build artifacts
dist/
build/
*.tsbuildinfo

# Runtime logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# Python local environment (used for tooling)
.venv/

# macOS / editor noise
.DS_Store
.vscode/
.idea/

# Raw and processed import files (bank exports / generated intermediates)
imports/raw/*
imports/processed/*
!imports/raw/.gitkeep
!imports/processed/.gitkeep
